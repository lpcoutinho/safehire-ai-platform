bucket                      = "safehire-tofu-state"
key                         = "local/terraform.tfstate"
region                      = "us-east-1"
endpoints = {
  s3       = "http://localhost:4566"
  dynamodb = "http://localhost:4566"
  sts      = "http://localhost:4566"
}
skip_credentials_validation = true
skip_metadata_api_check     = true
use_path_style              = true
access_key                  = "test"
secret_key                  = "test"
encrypt                     = false
